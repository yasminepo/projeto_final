from controller import usuario_controller


def escolher_evento():
    eventos = usuario_controller.controlador_listar_eventos()

    print("\n===== ESCOLHER EVENTO =====")

    for i, evento in enumerate(eventos):
        print(f"{i + 1} - {evento['nome']} ({evento['data']})")

    while True:
        try:
            escolha = int(input("\nEscolha o evento: "))

            if 1 <= escolha <= len(eventos):
                return escolha - 1

            print("Evento inválido.")

        except ValueError:
            print("Digite um número válido.")



def tela_remover():
    """
    Exibe a tela de remoção de um convidado.
    """

    print("\n===== REMOVER CONVIDADO =====")

    indice_evento = escolher_evento()

    nome = input("Nome do convidado: ")

    sucesso, mensagem = usuario_controller.controlador_remover_convidado(
        indice_evento,
        nome
    )

    print(mensagem)

    input("\nPressione Enter para voltar ao menu...")



def tela_remover_evento():
    """
    Exibe a tela de remoção de um evento.
    """

    print("\n===== REMOVER EVENTO =====")

    eventos = usuario_controller.controlador_listar_eventos()

    if len(eventos) == 0:
        print("Nenhum evento cadastrado.")
        input("\nPressione Enter para voltar...")
        return


    for i, evento in enumerate(eventos):
        print(f"{i + 1} - {evento['nome']} ({evento['data']})")


    while True:
        try:
            escolha = int(input("\nEscolha o evento que deseja remover: "))

            if 1 <= escolha <= len(eventos):

                indice_evento = escolha - 1

                sucesso, mensagem = usuario_controller.controlador_remover_evento(
                    indice_evento
                )

                print(mensagem)

                break

            else:
                print("Evento inválido.")

        except ValueError:
            print("Digite um número válido.")


    input("\nPressione Enter para voltar ao menu...")
